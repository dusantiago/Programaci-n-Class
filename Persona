import java.util.Scanner;

public class Persona {

    // Atributos de clase (según lo solicitado)
    private String nombre = "";
    private int edad = 0;
    private double sueldo = 0;
    private int documento = 0;
    private char sexo = 'N';

    // Constructor de clase
    Persona(String nombre_, int edad_, double sueldo_, int documento_, char sexo_) {
        this.nombre = nombre_;
        this.edad = edad_;
        this.sueldo = sueldo_;
        this.documento = documento_;
        this.sexo = sexo_;
    }

    // Constructor vacío (opcional)
    Persona() {
        this("", 0, 0, 0, 'N');
    }

    // Métodos de clase

    // Leer nombre desde consola
    public void leerNombre() {
        Scanner input = new Scanner(System.in);
        this.nombre = input.nextLine();
    }

   
    public void setNombre(String nombre_) {
        this.nombre = nombre_;
    }

    public void setEdad(int edad_) {
        this.edad = edad_;
    }

    public void setSueldo(double sueldo_) {
        this.sueldo = sueldo_;
    }

    public void setDocumento(int doc_) {
        this.documento = doc_;
    }

    public void setSexo(char sexo_) {
        this.sexo = sexo_;
    }


    public String getNombre() {
        return this.nombre;
    }

    public int getEdad() {
        return this.edad;
    }

    public double getSueldo() {
        return this.sueldo;
    }

    public int getDocumento() {
        return this.documento;
    }

    public char getSexo() {
        return this.sexo;
    }
}
